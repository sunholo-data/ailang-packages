-- Entitlements handler
--
-- GET /billing/me/entitlements
--
-- Returns the current effective entitlements for the authenticated user.
-- Requires Firebase Auth bearer token.

module sunholo/billing_service_api/entitlements_handler

import std/json (encode, jo, js, kv)
import std/result (Ok, Err)
import std/string (intToStr)
import pkg/sunholo/billing_store/entitlements_repo (getEntitlements)
import pkg/sunholo/billing_store/usage_repo (getUsage)
import pkg/sunholo/billing_entitlements/entitlement (freeEntitlements)
import pkg/sunholo/billing_entitlements/plan (Plan, parseCatalog)
import pkg/sunholo/config/loader (optionalEnv)
import pkg/sunholo/billing_entitlements/quota_policy (remainingRequests, remainingUnits, requestUsagePercent)

-- Get current entitlements for the authenticated user
@route("GET", "/billing/me/entitlements")
export func handleGetEntitlements(
  principalId: string,
  currentPeriod: string
) -> Result[string, string] ! {Net, FS, Env}
  requires { length(principalId) > 0 && length(currentPeriod) > 0 }
=
  -- Load entitlements (fall back to free tier from config if not found)
  let catalog = parseCatalog(optionalEnv("BILLING_PLAN_CATALOG", "[]"))
  in let ent = match getEntitlements(principalId) {
    Ok(e) => e,
    Err(_) => freeEntitlements(principalId, catalog)
  }
  in -- Load current usage
  let usage = match getUsage(principalId, currentPeriod) {
    Ok(u) => u,
    Err(_) => { unitsCompleted: 0, requests: 0, bytesProcessed: 0, subUnits: 0 }
  }
  in let requestsLeft = remainingRequests(ent, usage.requests)
  in let unitsLeft = remainingUnits(ent, usage.unitsCompleted)
  in let usagePct = requestUsagePercent(ent, usage.requests)
  in Ok(encode(jo([
    kv("plan", js(ent.plan)),
    kv("status", js(ent.status)),
    kv("canOperate", js(if ent.canOperate then "true" else "false")),
    kv("apiAccess", js(if ent.apiAccess then "true" else "false")),
    kv("maxFileSizeMb", js(intToStr(ent.maxFileSizeMb))),
    kv("monthlyRequestLimit", js(intToStr(ent.monthlyRequestLimit))),
    kv("monthlyRequestsUsed", js(intToStr(usage.requests))),
    kv("remainingRequests", js(intToStr(requestsLeft))),
    kv("monthlyUnitLimit", js(intToStr(ent.monthlyUnitLimit))),
    kv("unitsUsed", js(intToStr(usage.unitsCompleted))),
    kv("remainingUnits", js(intToStr(unitsLeft))),
    kv("usagePercent", js(intToStr(usagePct))),
    kv("maxConcurrentJobs", js(intToStr(ent.maxConcurrentJobs))),
    kv("gracePeriod", js(if ent.gracePeriod then "true" else "false"))
  ])))
