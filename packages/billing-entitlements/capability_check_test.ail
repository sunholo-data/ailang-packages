-- Tests for capability checks and quota policy
--
-- Uses inline test catalogs — no dependency on production plan values.

module sunholo/billing_entitlements/capability_check_test

import ./entitlement (Entitlements, resolveEntitlements, freeEntitlements)
import ./capability_check (canOperate, canUseApi, AllowDecision, OperationRequest)
import ./quota_policy (isOverRequestLimit, isOverUnitLimit, remainingRequests, remainingUnits, requestUsagePercent, isNearLimit)
import ./usage_policy (applyDelta, emptyUsage, usageDelta)
import ./plan (Plan)

-- Test fixture: known plan values for deterministic assertions
func testCatalog() -> [{key: string, plan: Plan}] = [
  { key: "free", plan: { name: "free", monthlyRequestLimit: 100, monthlyUnitLimit: 20, maxFileSizeMb: 10, apiAccess: false, maxConcurrentJobs: 1 } },
  { key: "pro_monthly", plan: { name: "pro", monthlyRequestLimit: 5000, monthlyUnitLimit: 500, maxFileSizeMb: 50, apiAccess: true, maxConcurrentJobs: 3 } }
]

func testFreeEnt(id: string) -> Entitlements = freeEntitlements(id, testCatalog())

-- ============================================================
-- canOperate tests
-- ============================================================

test "canOperate allows free tier web request under limits" {
  let ent = testFreeEnt("u1")
  in let req = { fileSizeMb: 5, isApiRequest: false }
  in match canOperate(ent, req, 0, 0) {
    Allow => true,
    Deny(_) => false
  }
}

test "canOperate denies API request when apiAccess is false" {
  let ent = testFreeEnt("u2")
  in let req = { fileSizeMb: 5, isApiRequest: true }
  in match canOperate(ent, req, 0, 0) {
    Allow => false,
    Deny(msg) => length(msg) > 0
  }
}

test "canOperate allows API request on pro tier" {
  let sub = { status: "active", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "u3")
  in let req = { fileSizeMb: 25, isApiRequest: true }
  in match canOperate(ent, req, 100, 10) {
    Allow => true,
    Deny(_) => false
  }
}

test "canOperate denies file exceeding size limit" {
  let ent = testFreeEnt("u4")
  in let req = { fileSizeMb: 15, isApiRequest: false }
  in match canOperate(ent, req, 0, 0) {
    Allow => false,
    Deny(msg) => length(msg) > 0
  }
}

test "canOperate denies when request limit reached" {
  let ent = testFreeEnt("u5")
  in let req = { fileSizeMb: 5, isApiRequest: false }
  in match canOperate(ent, req, 100, 0) {
    Allow => false,
    Deny(_) => true
  }
}

test "canOperate denies when unit limit reached" {
  let ent = testFreeEnt("u6")
  in let req = { fileSizeMb: 5, isApiRequest: false }
  in match canOperate(ent, req, 0, 20) {
    Allow => false,
    Deny(_) => true
  }
}

test "canOperate allows pro tier with large file under limit" {
  let sub = { status: "active", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "u7")
  in let req = { fileSizeMb: 50, isApiRequest: false }
  in match canOperate(ent, req, 4999, 499) {
    Allow => true,
    Deny(_) => false
  }
}

test "canOperate denies pro tier at exact request limit" {
  let sub = { status: "active", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "u8")
  in let req = { fileSizeMb: 1, isApiRequest: false }
  in match canOperate(ent, req, 5000, 0) {
    Allow => false,
    Deny(_) => true
  }
}

-- ============================================================
-- canUseApi tests
-- ============================================================

test "canUseApi returns false when apiAccess is false" {
  canUseApi(testFreeEnt("u9")) == false
}

test "canUseApi returns true for pro tier" {
  let sub = { status: "active", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "u10")
  in canUseApi(ent) == true
}

-- ============================================================
-- Quota policy tests
-- ============================================================

test "isOverRequestLimit false when under limit" {
  isOverRequestLimit(testFreeEnt("u11"), 50) == false
}

test "isOverRequestLimit true at exact limit" {
  isOverRequestLimit(testFreeEnt("u12"), 100) == true
}

test "isOverUnitLimit false when under" {
  isOverUnitLimit(testFreeEnt("u13"), 19) == false
}

test "isOverUnitLimit true at limit" {
  isOverUnitLimit(testFreeEnt("u14"), 20) == true
}

test "remainingRequests returns correct value" {
  remainingRequests(testFreeEnt("u15"), 30) == 70
}

test "remainingRequests returns 0 when over limit" {
  remainingRequests(testFreeEnt("u16"), 150) == 0
}

test "remainingUnits returns correct value" {
  remainingUnits(testFreeEnt("u17"), 5) == 15
}

test "requestUsagePercent at 50% usage" {
  requestUsagePercent(testFreeEnt("u18"), 50) == 50
}

test "requestUsagePercent caps at 100" {
  requestUsagePercent(testFreeEnt("u19"), 200) == 100
}

test "requestUsagePercent is 0 with no usage" {
  requestUsagePercent(testFreeEnt("u20"), 0) == 0
}

test "isNearLimit false at 79%" {
  isNearLimit(testFreeEnt("u21"), 79) == false
}

test "isNearLimit true at 80%" {
  isNearLimit(testFreeEnt("u22"), 80) == true
}

-- ============================================================
-- Usage policy tests
-- ============================================================

test "emptyUsage is all zeros" {
  let u = emptyUsage()
  in u.unitsCompleted == 0 && u.requests == 0
    && u.bytesProcessed == 0 && u.subUnits == 0
}

test "usageDelta creates single-unit delta" {
  let d = usageDelta(5, 1024, 2)
  in d.units == 1 && d.requests == 5 && d.bytes == 1024 && d.subUnits == 2
}

test "applyDelta adds to current usage" {
  let current = { unitsCompleted: 10, requests: 50, bytesProcessed: 5000, subUnits: 3 }
  in let delta = usageDelta(5, 1024, 2)
  in let updated = applyDelta(current, delta)
  in updated.unitsCompleted == 11 && updated.requests == 55
    && updated.bytesProcessed == 6024 && updated.subUnits == 5
}

test "applyDelta from empty usage" {
  let delta = usageDelta(10, 2048, 0)
  in let updated = applyDelta(emptyUsage(), delta)
  in updated.unitsCompleted == 1 && updated.requests == 10
    && updated.bytesProcessed == 2048 && updated.subUnits == 0
}
