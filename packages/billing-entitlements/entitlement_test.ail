-- Tests for entitlement resolution and plan catalog
--
-- Uses inline test catalogs — no dependency on production plan values.

module sunholo/billing_entitlements/entitlement_test

import ./entitlement (resolveEntitlements, freeEntitlements)
import ./plan (Plan, lookupPlan, parseCatalog, fallbackPlan, freePlanFromCatalog)
import std/result (Ok, Err)

-- Test fixture: a catalog with known values for deterministic assertions.
-- These are NOT production values — they exist only for testing the mechanism.
func testCatalog() -> [{key: string, plan: Plan}] = [
  { key: "free", plan: { name: "free", monthlyRequestLimit: 100, monthlyUnitLimit: 20, maxFileSizeMb: 10, apiAccess: false, maxConcurrentJobs: 1 } },
  { key: "pro_monthly", plan: { name: "pro", monthlyRequestLimit: 5000, monthlyUnitLimit: 500, maxFileSizeMb: 50, apiAccess: true, maxConcurrentJobs: 3 } },
  { key: "business_monthly", plan: { name: "business", monthlyRequestLimit: 20000, monthlyUnitLimit: 2000, maxFileSizeMb: 100, apiAccess: true, maxConcurrentJobs: 10 } }
]

-- ============================================================
-- Plan catalog tests
-- ============================================================

test "fallbackPlan has minimal limits" {
  let p = fallbackPlan()
  in p.name == "fallback" && p.monthlyRequestLimit == 1
    && p.apiAccess == false && p.maxConcurrentJobs == 1
}

test "freePlanFromCatalog finds free plan" {
  let p = freePlanFromCatalog(testCatalog())
  in p.name == "free" && p.monthlyRequestLimit == 100
}

test "freePlanFromCatalog returns fallback when no free plan" {
  let catalog = [{ key: "pro", plan: { name: "pro", monthlyRequestLimit: 5000, monthlyUnitLimit: 500, maxFileSizeMb: 50, apiAccess: true, maxConcurrentJobs: 3 } }]
  in let p = freePlanFromCatalog(catalog)
  in p.name == "fallback"
}

test "lookupPlan finds pro in catalog" {
  match lookupPlan(testCatalog(), "pro_monthly") {
    Ok(p) => p.name == "pro" && p.monthlyRequestLimit == 5000,
    Err(_) => false
  }
}

test "lookupPlan finds business in catalog" {
  match lookupPlan(testCatalog(), "business_monthly") {
    Ok(p) => p.name == "business" && p.maxConcurrentJobs == 10,
    Err(_) => false
  }
}

test "lookupPlan returns Err for unknown key" {
  match lookupPlan(testCatalog(), "enterprise_yearly") {
    Ok(_) => false,
    Err(_) => true
  }
}

test "parseCatalog parses valid JSON" {
  let json = "[{\"key\":\"test\",\"name\":\"test_plan\",\"monthlyRequestLimit\":999,\"monthlyUnitLimit\":99,\"maxFileSizeMb\":25,\"apiAccess\":true,\"maxConcurrentJobs\":2}]"
  in let catalog = parseCatalog(json)
  in match lookupPlan(catalog, "test") {
    Ok(p) => p.name == "test_plan" && p.monthlyRequestLimit == 999 && p.apiAccess == true,
    Err(_) => false
  }
}

test "parseCatalog returns empty on invalid JSON" {
  let catalog = parseCatalog("not json")
  in length(catalog) == 0
}

-- ============================================================
-- Entitlement resolution tests
-- ============================================================

test "active subscription gets full plan entitlements" {
  let sub = { status: "active", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_1")
  in ent.plan == "pro" && ent.status == "active"
    && ent.apiAccess == true && ent.monthlyRequestLimit == 5000
    && ent.gracePeriod == false
}

test "trialing subscription gets full plan entitlements" {
  let sub = { status: "trialing", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_2")
  in ent.status == "trialing" && ent.apiAccess == true
}

test "past_due subscription gets grace period" {
  let sub = { status: "past_due", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_3")
  in ent.status == "grace" && ent.gracePeriod == true
    && ent.apiAccess == true
}

test "canceled subscription falls back to free" {
  let sub = { status: "canceled", planKey: "pro_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_4")
  in ent.plan == "free" && ent.status == "free"
    && ent.apiAccess == false && ent.monthlyRequestLimit == 100
}

test "unknown plan key falls back to free" {
  let sub = { status: "active", planKey: "nonexistent_plan", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_5")
  in ent.plan == "free"
}

test "freeEntitlements returns free tier from catalog" {
  let ent = freeEntitlements("user_6", testCatalog())
  in ent.plan == "free" && ent.maxFileSizeMb == 10
    && ent.monthlyRequestLimit == 100 && ent.maxConcurrentJobs == 1
    && ent.canOperate == true
}

test "business plan gets full limits" {
  let sub = { status: "active", planKey: "business_monthly", cancelAtPeriodEnd: false }
  in let ent = resolveEntitlements(sub, testCatalog(), "user_7")
  in ent.plan == "business" && ent.monthlyRequestLimit == 20000
    && ent.maxConcurrentJobs == 10 && ent.maxFileSizeMb == 100
}
